{
	var otl=3DGetObj("OtlObj")
	otl.style.display=3D"block"
	otl.style.visibility=3D"visible"
	if( gOtlActiveClr =3D=3D "" ) gOtlActiveClr=3Ddocument.linkColor
	if( gOtlHiliteClr =3D=3D "" ) gOtlHiliteClr=3Ddocument.fgColor
