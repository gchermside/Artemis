		gOtlNormalClr=3Ddocument.bgColor
	else
		document.bgColor=3DgOtlNormalClr =20

	InitArray()

	if( ObjExists( parent.gCurSld ) ) {
		ChangeState( parent.gCurSld,gOtlNormalClr,gOtlHiliteClr )
