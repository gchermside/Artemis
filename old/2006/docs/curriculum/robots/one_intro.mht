function UpdNav()
{
	txt =3D "<center>";
	if( parent.GetHrefObj( parent.gCurSld ).mOrigVis =3D=3D 1 )
		txt +=3D "Slide " + parent.GetCurSldNum() + " of " + parent.GetNumSlds()
	else
