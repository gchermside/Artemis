le One</a></font></div>
  <div id=3DPPTC4 class=3DCTxt style=3D'display:none'><font size=3D2>
  <ul>
   <li>/*vehicle1.c*/</li>
   <li>#include &quot;logo.h&quot;</li>
   <li>#include &lt;dsensor.h&gt;</li>
   <br>
   <br>
   <li>int main(int argc, char *argv[]) {</li>
   <ul>
    <li><span style=3D'mso-spacerun:yes'>&nbsp; </span>int speed;</li>
   </ul>
   <li><span
       style=3D'mso-spacerun:yes'>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
       </span>sensorOn(2);<span style=3D'mso-spacerun:yes'>&nbsp;&nbsp; </s=
pan>/*
       turn on light sensor attached to 2 */</li>
   <li><span
       style=3D'mso-spacerun:yes'>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
       </span>while(1) {</li>
   <li><span
       style=3D'mso-spacerun:yes'>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp=
;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
       </span>/* the difference of current light and light in the room */</=
li>
   <li><span
       style=3D'mso-spacerun:yes'>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp=
;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
       </span>speed =3D LIGHT_2 - 25;</li>
   <li><span
       style=3D'mso-spacerun:yes'>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp=
;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
       </span>setSpeed(speed);<span style=3D'mso-spacerun:yes'>&nbsp;&nbsp;=
&nbsp;
       </span>/* sets speed to that difference */</li>
   <li><span
       style=3D'mso-spacerun:yes'>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp=
;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
       </span>forward(1);</li>
   <li><span
       style=3D'mso-spacerun:yes'>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
       </span>}</li>
   <li><span
       style=3D'mso-spacerun:yes'>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
       </span>return 0;</li>
   <li>}</li>
   <br>
   <br>
  </ul>
  </font></div>
